# رمز العملة المعتمد للعرض (المتطلب 12.4) — اختياري، الافتراضي JOD
NEXT_PUBLIC_CURRENCY_CODE=JOD

# رابط الاتصال بقاعدة بيانات PostgreSQL (مطلوب) — يقرأه Prisma من المتغيّر DATABASE_URL
# انسخ هذا الملف إلى .env واضبط القيمة وفق بيئتك.
DATABASE_URL="postgresql://user:password@localhost:5432/accounting?schema=public"
